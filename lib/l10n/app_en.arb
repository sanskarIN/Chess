  "guideHowChessWorksTitle": "How chess works",
  "guideHowChessWorksBody": "Two sides alternate legal moves. The goal is to checkmate the opposing king while keeping your own king safe.",
  "guidePiecesTitle": "Pieces and movement",
  "guidePiecesBody": "Pawns advance and capture diagonally; knights jump; bishops use diagonals; rooks use ranks and files; queens combine bishop and rook movement; kings move one safe square.",
  "guideCheckTitle": "Check",
  "guideCheckBody": "A checked king is under attack. The next move must capture the attacker, block the attack, or move the king safely.",
  "guideCheckmateTitle": "Checkmate",
  "guideCheckmateBody": "Checkmate occurs when a checked king has no legal escape. The attacking side wins immediately.",
  "guideStalemateTitle": "Stalemate",
  "guideStalemateBody": "Stalemate is a draw when the side to move is not in check but has no legal move.",
  "guideCastlingTitle": "Castling",
  "guideCastlingBody": "Castling moves the king two squares toward a rook. Neither piece may have moved, the path must be clear, and the king may not castle from, through, or into check.",
  "guideEnPassantTitle": "En passant",
  "guideEnPassantBody": "A pawn may capture an adjacent pawn immediately after that pawn advances two squares, as though it advanced one square.",
  "guidePromotionTitle": "Promotion",
  "guidePromotionBody": "A pawn reaching the final rank must become a queen, rook, bishop, or knight.",
  "guideDrawsTitle": "Draws",
  "guideDrawsBody": "Games can draw by stalemate, agreement, threefold repetition, the fifty-move rule, insufficient material, or a timeout when mate is impossible.",
  "guideTimeControlsTitle": "Time controls",
  "guideTimeControlsBody": "A time control gives each player a starting clock and may add an increment after every move. No-clock games remain available.",
  "guideComputerTitle": "Computer opponent",
  "guideComputerBody": "The computer runs locally and does not need an account or Internet connection. Search is asynchronous so the interface remains responsive.",
  "guideDifficultyTitle": "Difficulty",
  "guideDifficultyBody": "Beginner through Grandmaster change local search budgets. These labels are not calibrated human ratings, and stronger levels can use more battery and time.",
  "guideLocalTitle": "Local two-player",
  "guideLocalBody": "Two people can share one device offline with optional names, clocks, board orientation, approvals, and rematches.",
  "guideFriendTitle": "Friend matches",
  "guideFriendBody": "Online friend play uses a temporary WebSocket relay while the room is active. The relay does not permanently store match history and may be self-hosted.",
  "guideTeamCodesTitle": "Team codes",
  "guideTeamCodesBody": "Hosts can create four- or six-digit temporary codes. Six digits are the default because the larger room space reduces collisions.",
  "guideDailyTitle": "Daily challenges",
  "guideDailyBody": "Three deterministic challenges refresh at device-local midnight and work offline. Device-clock or open-source data changes cannot be made tamper-proof.",
  "guideCoinsTitle": "Coins and rewards",
  "guideCoinsBody": "Coins are earned locally through eligible first completions and challenge claims. They have no real-money value and are recorded in an integrity-linked local ledger.",
  "guideHintsTitle": "Hints",
  "guideHintsBody": "Hints are generated locally before charging one hint token or earned coins. Failed hint generation does not charge the wallet.",
  "guideSavedTitle": "Saved games",
  "guideSavedBody": "Save, resume, rename, delete, import, export, and review games locally. Imports are parsed as chess notation and never executed.",
  "guideImportExportTitle": "FEN and PGN",
  "guideImportExportBody": "FEN represents one position; PGN represents tags and a move history. Both formats are strictly validated before use.",
  "guideAccessibilityTitle": "Accessibility",
  "guideAccessibilityBody": "Board squares expose coordinates, occupants, and state to assistive technology. Text scaling, contrast, reduced motion, and larger controls are supported by the interface architecture.",
  "guideSettingsTitle": "Settings",
  "guideSettingsBody": "Settings for appearance, sound, accessibility, language, privacy, gameplay, storage, and developer tools are delivered in the settings phase.",
  "guideDeveloperTitle": "Developer options",
  "guideDeveloperBody": "Developer tools will include diagnostics, a FEN editor, locale tests, economy controls, challenge simulation, and relay configuration without exposing secrets.",
  "guidePrivacyTitle": "Privacy and local data",
  "guidePrivacyBody": "No account, advertising identifier, analytics, location, contacts, camera, or microphone permission is required. Durable data stays on the device.",
  "guideOpenSourceTitle": "Open source",
  "guideOpenSourceBody": "The project source and self-hostable relay are published under GPL-compatible terms. Bundled dependencies and assets are documented separately.",
  "guideTroubleshootingTitle": "Troubleshooting",
  "guideTroubleshootingBody": "If storage fails, restart before clearing data. If friend play fails, verify the relay URL, protocol version, network, and room expiry. Invalid imports should be corrected at the source.",
  "guideUpcomingTitle": "Upcoming features",
  "guideUpcomingBody": "Planned work is labeled honestly in the feature catalog and documentation. Availability is never implied before implementation and testing.",
  "featureComputerTitle": "Offline computer matches",
  "featureComputerBody": "Four local difficulty profiles with White, Black, and Random side choice.",
  "featureLocalTitle": "Local two-player",
  "featureLocalBody": "Offline shared-device matches with clocks, undo policies, draw, resign, and rematch.",
  "featureFriendTitle": "Team-code friend matches",
  "featureFriendBody": "Temporary in-memory relay rooms with reconnect and state verification.",
  "featureChallengesTitle": "Daily challenges and rewards",
  "featureChallengesBody": "Deterministic local challenges, one-time claims, coins, hints, and an integrity-linked ledger.",
  "featureTutorialTitle": "Interactive tutorial",
  "featureTutorialBody": "Seventeen validated lessons with saved progress and one-time rewards.",
  "featurePracticeTitle": "Practice and puzzles",
  "featurePracticeBody": "Free board, custom FEN, mate, tactic, opening, and endgame exercises.",
  "featureSavedTitle": "Saved games and review",
  "featureSavedBody": "Local save, resume, rename, delete, FEN/PGN interchange, and move stepping.",
  "featureSettingsTitle": "Complete settings",
  "featureSettingsBody": "Appearance, sound, gameplay, accessibility, privacy, data, and developer groups.",
  "featureLocalizationTitle": "33 language packs",
  "featureLocalizationBody": "English plus 32 Indian language locales with fallback, RTL testing, and community review status.",
  "featureAudioTitle": "Original sound pack",
  "featureAudioBody": "Optional offline move, capture, check, challenge, clock, and connection sounds.",
  "featureHistoryTitle": "History and statistics",
  "featureHistoryBody": "Filterable local match history, statistics, and achievements.",
  "featureDataTitle": "Data export and import",
  "featureDataBody": "Versioned, selectable local backups with validation and preview.",
  "featurePremiumTitle": "Possible premium edition",
  "featurePremiumBody": "A future one-time-purchase edition is only a candidate; no purchase system exists in this build."
