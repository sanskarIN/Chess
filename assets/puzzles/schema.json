{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sanskarIN/Chess/assets/puzzles/schema.json",
  "title": "Chess-Master training positions",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "positions"],
  "properties": {
    "formatVersion": {
      "const": 1
    },
    "positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "titleKey",
          "descriptionKey",
          "fen",
          "solutionUci",
          "difficulty",
          "source",
          "license"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "type": {
            "enum": ["mate_in_one", "mate_in_two", "tactic", "opening", "endgame"]
          },
          "titleKey": {
            "type": "string",
            "minLength": 1
          },
          "descriptionKey": {
            "type": "string",
            "minLength": 1
          },
          "fen": {
            "type": "string",
            "minLength": 1
          },
          "solutionUci": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-h][1-8][a-h][1-8][qrbn]?$"
            }
          },
          "difficulty": {
            "enum": ["beginner", "intermediate", "advanced"]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
